---
// src/layouts/Layout.astro
import '../styles/global.css';
import Navbar from '../components/navbar.astro';

interface Props {
	title?: string;
}

const { title = "Ultranetic | The Abolition of Pain" } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#fffcf9] text-slate-900 selection:bg-rose-100 selection:text-rose-900">
		
		<div class="fixed inset-0 pointer-events-none z-0">
			<div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-rose-50 rounded-full blur-[120px] opacity-60"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-orange-50 rounded-full blur-[100px] opacity-40"></div>
		</div>

		<div class="fixed top-0 left-0 w-full z-50">
			<Navbar />
		</div>

		<main class="relative z-10">
			<slot />
		</main>

		<footer class="relative z-10 py-20 px-6 border-t border-rose-100 bg-white">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8 font-serif italic text-slate-400">
				<p>For a future of love and kindness.</p>
				<p>Ultranetic &copy; 2026</p>
			</div>
		</footer>

		<style is:global>
			:root {
				--accent: #f43f5e; /* Rose-500 */
			}

			body {
				margin: 0;
				min-height: 100vh;
				overflow-x: hidden;
			}

			/* Typography Polish */
			h1, h2, h3, .font-serif {
				font-family: 'Playfair Display', serif;
			}

			p, body, .font-sans {
				font-family: 'Inter', sans-serif;
			}

			/* Remove the old text-gradient and replace with a "Visionary" version */
			.text-visionary {
				background: linear-gradient(to bottom right, #1a1a1b 40%, #f43f5e);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}

			/* Ensure images in cards are vibrant */
			img {
				display: block;
				max-width: 100%;
			}
		</style>
	</body>
</html>