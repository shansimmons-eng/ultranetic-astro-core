---
import '../styles/global.css';
import Navbar from '../components/navbar.astro';

interface Props {
	title?: string;
}

const { title = "Ultranetic | Post-Darwinian Transition" } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#fffcf9] text-slate-900 antialiased font-sans selection:bg-rose-100">
		
		<div class="fixed inset-0 pointer-events-none z-0">
			<div class="absolute top-[-10%] right-[-10%] w-[60%] h-[60%] bg-rose-50/50 rounded-full blur-[120px]"></div>
			<div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-orange-50/30 rounded-full blur-[100px]"></div>
		</div>

		<header class="fixed top-0 left-0 w-full z-50 bg-white/70 backdrop-blur-md border-b border-rose-100/50">
			<Navbar />
		</header>

		<main class="relative z-10">
			<slot />
		</main>

		<footer class="relative z-10 py-24 px-6 border-t border-rose-100 bg-white/50">
			<div class="max-w-7xl mx-auto text-center">
				<p class="font-mono text-[10px] uppercase tracking-[0.5em] text-rose-400 mb-4">The Transition is Beginning</p>
				<p class="text-slate-400 text-sm italic">"A human experience free of involuntary pain."</p>
			</div>
		</footer>

		<style is:global>
			body { margin: 0; min-height: 100vh; }
			h1, h2, h3 { letter-spacing: -0.04em; }
		</style>
	</body>
</html>