---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/layout.astro';
import TechCard from '../../components/TechCard.astro';

export const prerender = false;

const { slug } = Astro.params;

// Instead of getEntry, we get everything and find the best match
const allEntries = await getCollection('lore');
const entry = allEntries.find((e) => e.id.includes(slug) || slug.includes(e.id));

if (!entry) {
    console.log("DEBUG: Could not find", slug, "in", allEntries.map(e => e.id));
    return Astro.redirect('/404');
}

const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
    <main class="relative z-10 px-6 py-20 max-w-4xl mx-auto">
    <nav class="mb-8">
        <a href="/lore" class="inline-block px-4 py-2 border border-[#00f2ff]/40 bg-[#00f2ff]/10 text-[#00f2ff] font-mono text-xs hover:bg-[#00f2ff]/20 transition-colors">
            ← RETURN TO LEDGER
        </a>
    </nav>
    
    <TechCard class="p-0 overflow-hidden border-[#00f2ff]/20 bg-black/40 backdrop-blur-xl">
        {entry.data.image && (
            <div class="relative w-full h-[400px] border-b border-[#00f2ff]/20 overflow-hidden">
                <img 
                    src={entry.data.image} 
                    alt={entry.data.title}
                    class="w-full h-full object-cover opacity-80"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
            </div>
        )}

        <article class="cu-markdown p-8 md:p-14">
            <h1 class="text-4xl md:text-6xl font-bold uppercase mb-4 text-white">
                {entry.data.title}
            </h1>
            
            {entry.data.status && (
                <div class="mb-10 inline-block px-2 py-1 bg-[#00f2ff]/10 border border-[#00f2ff]/30 text-[#00f2ff] font-mono text-[10px] uppercase tracking-widest">
                    Status: {entry.data.status}
                </div>
            )}

            <Content />
        </article>
    </TechCard>
</main>
</Layout>

<style is:global>
    /* Your existing styles - I kept them exactly as they were */
    .cu-markdown h1 {
        @apply text-4xl md:text-6xl font-display font-bold uppercase tracking-tighter mb-10 bg-clip-text text-transparent bg-gradient-to-br from-white to-white/40;
    }
    .cu-markdown h2 {
        @apply text-2xl md:text-3xl font-display font-bold uppercase tracking-widest mb-6 mt-16 border-l-2 border-[#00f2ff] pl-6;
    }
    .cu-markdown h3 {
        @apply text-xl font-mono text-[#00f2ff] tracking-[0.2em] mb-4 mt-10;
    }
    .cu-markdown p {
        @apply text-lg text-white/70 leading-relaxed mb-6;
    }
    .cu-markdown ul {
        @apply list-none mb-8 space-y-4;
    }
    .cu-markdown li {
        @apply text-white/70 relative pl-6;
    }
    .cu-markdown li::before {
        content: "›";
        @apply absolute left-0 text-[#00f2ff] font-mono text-xl leading-none top-[-2px];
    }
    .cu-markdown strong {
        @apply text-white font-semibold;
    }
    .cu-markdown blockquote {
        @apply border-l-4 border-[#00f2ff]/50 bg-white/5 p-6 my-8 text-white/80 font-mono text-sm;
    }
</style>