---
// src/pages/lore/index.astro - THE LUMINOUS SANCTUARY (Sans-Serif Edition)
import Layout from '../../layouts/layout.astro'; 
import { getCollection } from 'astro:content';

const loreEntries = await getCollection('lore');
---

<Layout title="The Ultranetic Blueprint | Foundations of Veracity">
    <main class="relative z-10 px-6 py-24 max-w-6xl mx-auto">
        
        <header class="mb-32 text-center max-w-4xl mx-auto">
            <div class="inline-block px-5 py-1.5 mb-10 border border-rose-200 text-rose-500 font-sans text-[10px] font-bold tracking-[0.4em] uppercase rounded-full bg-rose-50/30">
                The Great Transition // Phase 01
            </div>
            
            <h1 class="text-6xl md:text-8xl font-black text-slate-900 tracking-tighter mb-10 leading-[0.9]">
                The Abolition <br/> of <span class="text-rose-500">Pain.</span>
            </h1>
            
            <div class="space-y-8 text-xl md:text-2xl text-slate-600 font-light leading-relaxed max-w-3xl mx-auto">
                <p>
                    "We are emerging from a death-cult era of engineered suffering. We have been zombies to a narrative of division for too long."
                </p>
                <p class="text-slate-900 font-medium italic">
                    Ultranetic is the technical and moral architecture built to establish <strong>veracity, love, and progress.</strong>
                </p>
            </div>

            <div class="mt-20">
                <div class="h-16 w-px bg-gradient-to-b from-rose-500 to-transparent mx-auto"></div>
                <p class="mt-6 font-sans text-[10px] font-bold uppercase tracking-[0.3em] text-rose-400">The Ledger of Veracity</p>
            </div>
        </header>

        <div id="blueprint" class="grid grid-cols-1 md:grid-cols-2 gap-10">
            {loreEntries.map(entry => (
                <a href={`/lore/${entry.slug || entry.id}`} class="block group no-underline">
                    <div class="h-full flex flex-col bg-white/60 backdrop-blur-sm border border-rose-100 shadow-sm hover:shadow-xl hover:shadow-rose-100/50 transition-all duration-500 rounded-xl overflow-hidden">
                        
                        {entry.data.image && (
                            <div class="relative w-full h-80 overflow-hidden">
                                <img 
                                    src={entry.data.image} 
                                    alt={entry.data.title}
                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                />
                            </div>
                        )}

                        <div class="p-10 flex flex-col flex-grow">
                            <h2 class="text-3xl font-extrabold text-slate-900 group-hover:text-rose-500 transition-colors duration-300 tracking-tight">
                                {entry.data.title}
                            </h2>
                            
                            {entry.data.description && (
                                <p class="mt-6 text-slate-600 leading-relaxed font-normal text-lg">
                                    {entry.data.description}
                                </p>
                            )}
                            
                            <div class="mt-auto pt-10 flex items-center justify-between border-t border-rose-50">
                                <div class="flex items-center gap-3">
                                    <span class="w-2 h-2 bg-rose-500 rounded-full animate-pulse shadow-[0_0_10px_rgba(244,63,94,0.4)]"></span>
                                    <span class="font-sans text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">
                                        Foundation: {entry.slug || entry.id}
                                    </span>
                                </div>
                                <span class="text-rose-400 font-bold text-xs uppercase tracking-widest group-hover:translate-x-2 transition-transform duration-300">Read ↗</span>
                            </div>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </main>
</Layout>