---
// src/pages/lore/index.astro - THE LUMINOUS EDITION
import Layout from '../../layouts/layout.astro'; 
import TechCard from '../../components/TechCard.astro';
import { getCollection } from 'astro:content';

const loreEntries = await getCollection('lore');
---

<Layout title="The Ultranetic Blueprint | A Future Without Pain">
    <main class="relative z-10 px-6 py-24 max-w-6xl mx-auto bg-[#fffcf9]">
        
        <header class="mb-32 text-center max-w-3xl mx-auto">
            <div class="inline-block px-6 py-2 mb-12 border-b-2 border-rose-200 text-rose-500 font-mono text-[11px] tracking-[0.5em] uppercase">
                Project Ultranetic // The Transition
            </div>
            
            <h1 class="text-6xl md:text-8xl font-serif font-light text-slate-900 tracking-tight mb-10 leading-none">
                The Abolition of <span class="italic text-rose-500">Pain.</span>
            </h1>
            
            <div class="space-y-8 text-2xl text-slate-600 font-light leading-relaxed italic">
                <p>
                    "We are emerging from a death-cult era of engineered suffering. We have been zombies to a narrative of division for too long."
                </p>
                <p class="text-slate-900 font-normal not-italic">
                    Ultranetic is the literal way forward—a technical and moral architecture built for <strong>love, kindness, and progress.</strong>
                </p>
            </div>

            <div class="mt-16">
                <div class="h-20 w-px bg-gradient-to-b from-rose-500 to-transparent mx-auto"></div>
                <p class="mt-4 font-serif text-sm uppercase tracking-widest text-rose-400">Explore the Foundations</p>
            </div>
        </header>

        <div id="blueprint" class="grid grid-cols-1 md:grid-cols-2 gap-12">
            {loreEntries.map(entry => (
                <a href={`/lore/${entry.slug || entry.id}`} class="block group no-underline">
                    <div class="h-full flex flex-col bg-white border border-rose-100 shadow-sm hover:shadow-2xl hover:shadow-rose-100 transition-all duration-700 p-0 rounded-sm overflow-hidden">
                        
                        {entry.data.image && (
                            <div class="relative w-full h-80 overflow-hidden">
                                <img 
                                    src={entry.data.image} 
                                    alt={entry.data.title}
                                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent to-transparent opacity-40"></div>
                            </div>
                        )}

                        <div class="p-10 flex flex-col flex-grow">
                            <h2 class="text-3xl font-serif font-light text-slate-800 group-hover:text-rose-500 transition-colors duration-500">
                                {entry.data.title}
                            </h2>
                            
                            {entry.data.description && (
                                <p class="mt-6 text-slate-500 leading-relaxed font-light text-lg">
                                    {entry.data.description}
                                </p>
                            )}
                            
                            <div class="mt-auto pt-10 flex items-center justify-between border-t border-rose-50 border-dashed">
                                <div class="flex items-center gap-3">
                                    <span class="w-2 h-2 bg-rose-400 rounded-full shadow-[0_0_8px_rgba(244,63,94,0.6)]"></span>
                                    <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400">
                                        Pathway: {entry.slug || entry.id}
                                    </div>
                                <span class="text-rose-300 group-hover:translate-x-2 transition-transform duration-500 italic font-serif">Open →</span>
                            </div>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </main>
</Layout>